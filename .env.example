APP_NAME=Academic Assistant API
APP_VERSION=0.1.0
APP_DATABASE_URL=sqlite:///./backend_app.db
LEGACY_DB_PATH=documents.db
UPLOAD_ROOT=uploads
SCHEDULE_INDEX_DIR_TEMPLATE=indexes/schedules/{schedule_id}

JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
REFRESH_TOKEN_EXPIRY_DAYS=7
REFRESH_COOKIE_NAME=refresh_token
COOKIE_SECURE=true
COOKIE_SAMESITE=none

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_TOKENINFO_ENDPOINT=https://oauth2.googleapis.com/tokeninfo

SESSION_EMBEDDING_THRESHOLD=0.65
SESSION_KEYWORD_OVERLAP_MIN=0.30
BRIEFING_MAX_TOKENS=2048
BRIEFING_MODEL=gemma3:12b
CHAT_CONTEXT_TURNS=8
ALLOWED_ORIGINS=https://academic-assistant-frontend.vercel.app,http://localhost:3000

OLLAMA_BASE_URL=http://127.0.0.1:11434
QWEN_MODEL=qwen2.5:7b
GEMMA_BACKEND=gemini
GEMMA_GEMINI_MODEL=gemma-4-26b-a4b-it
GEMMA_OLLAMA_MODEL=gemma4:e4b
DISABLE_OLLAMA_THINKING=true
USE_LEGACY_SEGMENT_CHUNKING=false

GOOGLE_OAUTH_LOCAL_HOST=localhost
GOOGLE_OAUTH_LOCAL_PORT=8080
